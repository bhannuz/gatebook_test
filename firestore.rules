rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email — must match the one in index.html and admin.html
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@gatebook.app';
    }

    match /apartments/{uid} {
      // Owner can read/write their own apartment
      // Admin can read all apartments
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{docId} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Admin can update plan/expiry on any apartment doc
    match /apartments/{uid} {
      allow update: if isAdmin();
    }
  }
}
